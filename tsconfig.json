{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "sourceMap": true,
    "skipLibCheck": true
  },
  "include": ["*.ts", "config/**/*.ts", "controllers/**/*.ts", "middlewares/**/*.ts", "models/**/*.ts", "routes/**/*.ts", "utils/**/*.ts", "validators/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
